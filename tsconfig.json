{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES5",
    "importHelpers": true,
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "strict": true,
    "allowJs": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDirs": [
      "src",
      "tests"
    ],
    "sourceMap": false,
    "outDir": "./dist",
    "types": [
      "screeps",
      "node",
      "lodash",
      "jest"
    ],
    "paths": {
      "*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "tests/spawn/SpawnQueue.test.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "rollup.config.js"
  ]
}